{
  "$schema": "http://json-schema.org/draft/2020-12/schema#",
  "type": "object",
  "properties": {
    "showLabels": {
      "type": "boolean"
    },
    "showAggregatedLabels": {
      "type": "boolean"
    },
    "showEmptyHighlights": {
      "type": "boolean"
    },
    "protectElements": {
      "type": "boolean"
    },
    "showDocumentStructure": {
      "type": "boolean"
    },
    "documentStructureWidth": {
      "type": "number"
    },
    "showImages": {
      "type": "boolean"
    },
    "showTables": {
      "type": "boolean"
    },
    "keyboardCursorEnabled": {
      "type": "boolean"
    },
    "showRelationLabels": {
      "type": "boolean"
    },
    "lineSpacing": {
      "type": "string",
      "enum": ["low", "mid", "high", "xhigh"]
    }
  },
  "additionalProperties": false
}
