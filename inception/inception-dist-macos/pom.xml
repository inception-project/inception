<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>de.tudarmstadt.ukp.inception.app</groupId>
    <artifactId>inception-app</artifactId>
    <version>41.0-SNAPSHOT</version>
    <relativePath>..</relativePath>
  </parent>

  <artifactId>inception-dist-macos</artifactId>
  <name>INCEpTION - App - macOS application</name>
  <packaging>pom</packaging>

  <dependencies>
    <dependency>
      <groupId>de.tudarmstadt.ukp.inception.app</groupId>
      <artifactId>inception-app-webapp</artifactId>
      <version>${project.version}</version>
      <type>jar</type>
      <classifier>lib</classifier>
    </dependency>
  </dependencies>

  <profiles>
    <profile>
      <id>dist-macos</id>

      <properties>
        <!-- Empty defaults so unset 'jdk.<arch>.home' properties resolve to
             an empty string instead of the literal '${…}'. Override in
             ~/.m2/settings.xml or via -D. -->
        <jdk.aarch64.home />
        <jdk.x86_64.home />
      </properties>

      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-enforcer-plugin</artifactId>
            <executions>
              <execution>
                <id>enforce-dist-prerequisites</id>
                <phase>validate</phase>
                <goals>
                  <goal>enforce</goal>
                </goals>
                <configuration>
                  <rules>
                    <requireOS>
                      <family>mac</family>
                      <message>The 'dist-macos' profile builds a macOS application bundle and must be run on macOS.</message>
                    </requireOS>
                    <requireProperty>
                      <property>mac.signing.identity</property>
                      <message>The 'dist-macos' profile requires the 'mac.signing.identity' property to be set, e.g. -Dmac.signing.identity="Developer ID Application: Your Name (TEAMID)". This identity is used to codesign native libraries and the resulting DMG.</message>
                    </requireProperty>
                  </rules>
                  <fail>true</fail>
                </configuration>
              </execution>
            </executions>
          </plugin>

          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-dependency-plugin</artifactId>
            <executions>
              <execution>
                <id>stage-dependencies</id>
                <phase>prepare-package</phase>
                <goals>
                  <goal>copy-dependencies</goal>
                </goals>
                <configuration>
                  <outputDirectory>${project.build.directory}/jpackage-input</outputDirectory>
                  <includeScope>runtime</includeScope>
                  <overWriteReleases>false</overWriteReleases>
                  <overWriteSnapshots>true</overWriteSnapshots>
                  <overWriteIfNewer>true</overWriteIfNewer>
                </configuration>
              </execution>
              <execution>
                <id>stage-provided-dependencies</id>
                <phase>prepare-package</phase>
                <goals>
                  <goal>copy-dependencies</goal>
                </goals>
                <configuration>
                  <outputDirectory>${project.build.directory}/jpackage-input</outputDirectory>
                  <includeScope>provided</includeScope>
                  <overWriteReleases>false</overWriteReleases>
                  <overWriteSnapshots>true</overWriteSnapshots>
                  <overWriteIfNewer>true</overWriteIfNewer>
                </configuration>
              </execution>
            </executions>
          </plugin>

          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>build-helper-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>parse-version</id>
                <phase>initialize</phase>
                <goals>
                  <goal>parse-version</goal>
                </goals>
              </execution>
            </executions>
          </plugin>

          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>create-icns</id>
                <phase>prepare-package</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>bash</executable>
                  <arguments>
                    <argument>${project.basedir}/src/main/scripts/create-icns.sh</argument>
                    <argument>${session.executionRootDirectory}/icon.png</argument>
                    <argument>${project.build.directory}/icon.icns</argument>
                  </arguments>
                </configuration>
              </execution>
              <execution>
                <id>process-native-libs</id>
                <phase>prepare-package</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>bash</executable>
                  <arguments>
                    <argument>${project.basedir}/src/main/scripts/process-native-libs.sh</argument>
                    <argument>${project.build.directory}/jpackage-input</argument>
                    <argument>${mac.signing.identity}</argument>
                  </arguments>
                </configuration>
              </execution>
              <execution>
                <id>package-dmg-aarch64</id>
                <phase>package</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>bash</executable>
                  <arguments>
                    <argument>${project.basedir}/src/main/scripts/package-dmg.sh</argument>
                    <argument>aarch64</argument>
                    <argument>${jdk.aarch64.home}</argument>
                    <argument>${mac.signing.identity}</argument>
                    <argument>${project.build.directory}/jpackage-input</argument>
                    <argument>${project.build.directory}/jpackage-aarch64</argument>
                    <argument>inception-app-webapp-${project.version}-lib.jar</argument>
                    <argument>de.tudarmstadt.ukp.inception.INCEpTION</argument>
                    <argument>${parsedVersion.majorVersion}.${parsedVersion.minorVersion}</argument>
                    <argument>${project.build.directory}/icon.icns</argument>
                    <argument>${project.basedir}/src/main/resources/entitlements.plist</argument>
                  </arguments>
                </configuration>
              </execution>
              <execution>
                <id>package-dmg-x86_64</id>
                <phase>package</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>bash</executable>
                  <arguments>
                    <argument>${project.basedir}/src/main/scripts/package-dmg.sh</argument>
                    <argument>x86_64</argument>
                    <argument>${jdk.x86_64.home}</argument>
                    <argument>${mac.signing.identity}</argument>
                    <argument>${project.build.directory}/jpackage-input</argument>
                    <argument>${project.build.directory}/jpackage-x86_64</argument>
                    <argument>inception-app-webapp-${project.version}-lib.jar</argument>
                    <argument>de.tudarmstadt.ukp.inception.INCEpTION</argument>
                    <argument>${parsedVersion.majorVersion}.${parsedVersion.minorVersion}</argument>
                    <argument>${project.build.directory}/icon.icns</argument>
                    <argument>${project.basedir}/src/main/resources/entitlements.plist</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>

    <profile>
      <id>release-macos</id>

      <build>
        <plugins>
          <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-enforcer-plugin</artifactId>
            <executions>
              <execution>
                <id>enforce-release-macos-prerequisites</id>
                <phase>validate</phase>
                <goals>
                  <goal>enforce</goal>
                </goals>
                <configuration>
                  <rules>
                    <requireOS>
                      <family>mac</family>
                      <message>The 'release-macos' profile notarizes macOS DMGs and must be run on macOS.</message>
                    </requireOS>
                    <requireProperty>
                      <property>mac.notarization.keychain.profile</property>
                      <message>The 'release-macos' profile requires the 'mac.notarization.keychain.profile' property to be set, e.g. -Dmac.notarization.keychain.profile="AC_NOTARY". Create the keychain profile once with: xcrun notarytool store-credentials.</message>
                    </requireProperty>
                  </rules>
                  <fail>true</fail>
                </configuration>
              </execution>
            </executions>
          </plugin>

          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>notarize-dmg-aarch64</id>
                <phase>verify</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>bash</executable>
                  <arguments>
                    <argument>${project.basedir}/src/main/scripts/notarize-dmg.sh</argument>
                    <argument>${project.build.directory}/jpackage-aarch64</argument>
                    <argument>${mac.notarization.keychain.profile}</argument>
                  </arguments>
                </configuration>
              </execution>
              <execution>
                <id>notarize-dmg-x86_64</id>
                <phase>verify</phase>
                <goals>
                  <goal>exec</goal>
                </goals>
                <configuration>
                  <executable>bash</executable>
                  <arguments>
                    <argument>${project.basedir}/src/main/scripts/notarize-dmg.sh</argument>
                    <argument>${project.build.directory}/jpackage-x86_64</argument>
                    <argument>${mac.notarization.keychain.profile}</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
