{
  "name": "@inception-project/${project.artifactId}",
  "version": "${semver}",
  "type": "module",
  "author": "INCEpTION Team",
  "license": "(MIT AND Apache-2.0)",
  "scripts": {
    "build": "node build.mjs",
    "test": "vitest run --reporter=junit --outputFile=\"../../../target/surefire-reports/vitest-test-report.xml\"",
    "format": "prettier --write \"**/*.{js,ts,css,scss,json,md,html}\"",
    "format:check": "prettier --check \"**/*.{js,ts,css,scss,json,md,html}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inception-project/inception.git"
  },
  "bugs": {
    "url": "https://github.com/inception-project/issues"
  },
  "overrides": {
    "minimatch": "${minimatch.version}",
    "immutable": "${immutable.version}",
    "undici": "${undici.version}"
  },
  "dependencies": {
    "@inception-project/inception-js-api": "file:../../../../inception-js-api/src/main/ts"
  },
  "devDependencies": {
    "esbuild": "${esbuild.version}",
    "esbuild-sass-plugin": "${esbuild-sass-plugin.version}",
    "eslint": "${eslint.version}",
    "eslint-config-prettier": "${eslint-config-prettier.version}",
    "eslint-plugin-import-x": "${eslint-plugin-import-x.version}",
    "eslint-plugin-n": "${eslint-plugin-n.version}",
    "eslint-plugin-promise": "${eslint-plugin-promise.version}",
    "fs-extra": "${fs-extra.version}",
    "jsdom": "${jsdom.version}",
    "prettier": "${prettier.version}",
    "prettier-plugin-svelte": "${prettier-plugin-svelte.version}",
    "sass": "${sass.version}",
    "svelte": "${svelte.version}",
    "@sveltejs/vite-plugin-svelte": "${sveltejs-vite-plugin-svelte.version}",
    "@testing-library/svelte": "${testing-library-svelte.version}",
    "temp-write": "${temp-write.version}",
    "@typescript-eslint/eslint-plugin": "${typescript-eslint-eslint-plugin.version}",
    "@typescript-eslint/parser": "${typescript-eslint-parser.version}",
    "@types/events": "${types-events.version}",
    "@types/jquery": "${types-jquery.version}",
    "@types/urijs": "${types-urijs.version}",
    "typescript": "${typescript.version}",
    "uuid": "${uuid.version}",
    "vite": "${vite.version}",
    "vitest": "${vitest.version}",
    "yargs": "${yargs.version}"
  }
}
